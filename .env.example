APP_NAME=SpeakEasy
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/spelling_bee?charset=utf8mb4

# Optional Merriam-Webster Collegiate Dictionary API key.
# When empty, the app uses the free Dictionary API at https://dictionaryapi.dev/.
MERRIAM_WEBSTER_API_KEY=
MERRIAM_WEBSTER_REFERENCE=collegiate

# Optional translation providers: none, mymemory, libretranslate
TRANSLATION_PROVIDER=mymemory
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Optional. Wikimedia is used by default for public thumbnail search.
IMAGE_PROVIDER=wikimedia
LIST_DELETE_PASSWORD=123456

# Optional AI image generation for word detail pages.
# Configure on the server to enable the "AI 生图" button.
AI_IMAGE_PROVIDER=tencent_hunyuan
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou
TENCENT_HUNYUAN_IMAGE_ACTION=TextToImageRapid
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional AI text-to-speech for the word audio manager.
# Uses OPENAI_API_KEY and saves generated MP3 files as the current US/UK audio.
AI_TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_US=alloy
OPENAI_TTS_VOICE_GB=alloy

# Optional Aliyun Intelligent Speech Interaction TTS provider.
# Set AI_TTS_PROVIDER=aliyun and configure an NLS AppKey plus either a Token
# or an AccessKey pair that can create NLS tokens automatically.
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_TOKEN=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_TOKEN_REGION=cn-shanghai
ALIYUN_TOKEN_ENDPOINT=https://nls-meta.cn-shanghai.aliyuncs.com/
ALIYUN_TTS_GATEWAY=https://nls-gateway-cn-shanghai.aliyuncs.com/stream/v1/tts
ALIYUN_TTS_FORMAT=mp3
ALIYUN_TTS_SAMPLE_RATE=16000
ALIYUN_TTS_VOICE_US=sarah
ALIYUN_TTS_VOICE_GB=mary
ALIYUN_TTS_VOICE_US_FEMALE=sarah
ALIYUN_TTS_VOICE_US_MALE=john
ALIYUN_TTS_VOICE_GB_FEMALE=mary
ALIYUN_TTS_VOICE_GB_MALE=arthur
ALIYUN_TTS_VOLUME=50
ALIYUN_TTS_SPEECH_RATE=0
ALIYUN_TTS_PITCH_RATE=0

# Optional BookLearner / 好词好句 MySQL storage.
# Leave disabled to run without saving analysis history.
BOOKLEARNER_MYSQL_ENABLED=0
BOOKLEARNER_MYSQL_HOST=127.0.0.1
BOOKLEARNER_MYSQL_PORT=3306
BOOKLEARNER_MYSQL_DATABASE=booklearner
BOOKLEARNER_MYSQL_USER=booklearner
BOOKLEARNER_MYSQL_PASSWORD=booklearner-pass
BOOKLEARNER_MYSQL_ADMIN_USER=root
BOOKLEARNER_MYSQL_ADMIN_PASSWORD=
