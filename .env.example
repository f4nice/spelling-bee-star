APP_NAME=拼词之星
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/spelling_bee?charset=utf8mb4

# Optional Merriam-Webster Collegiate Dictionary API key.
# When empty, the app uses the free Dictionary API at https://dictionaryapi.dev/.
MERRIAM_WEBSTER_API_KEY=
MERRIAM_WEBSTER_REFERENCE=collegiate

# Optional translation providers: none, mymemory, libretranslate
TRANSLATION_PROVIDER=mymemory
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Optional. Wikimedia is used by default for public thumbnail search.
IMAGE_PROVIDER=wikimedia
LIST_DELETE_PASSWORD=123456
